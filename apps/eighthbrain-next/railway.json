{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter eighthbrain-next build",
    "watchPatterns": ["apps/eighthbrain-next/**", "lib/config/**"]
  },
  "deploy": {
    "startCommand": "pnpm --filter eighthbrain-next start",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
