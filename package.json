{
  "name": "notes",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:notes-web": "pnpm --filter notes-next build",
    "build:android": "pnpm --filter notes-android build",
    "build:android:dist:dev": "pnpm --filter notes-android build:dist:dev",
    "build:android:dist:prod": "pnpm --filter notes-android build:dist:prod",
    "deps:install": "bash scripts/install-workspace-deps.sh",
    "db:migrate": "pnpm --filter @lib/db-marketing db:migrate",
    "db:migrate:baseline": "pnpm --filter @lib/db-marketing db:migrate:baseline",
    "db:verify": "pnpm --filter @lib/db-marketing db:verify",
    "db:embeddings:regenerate": "pnpm --filter @lib/db-marketing db:embeddings:regenerate",
    "test": "turbo run test",
    "verify:db-contracts": "pnpm --filter @lib/db-marketing check-types",
    "verify:notes-web": "pnpm --filter notes-next verify",
    "verify:android": "pnpm --filter notes-android verify",
    "verify:apps": "pnpm run verify:notes-web && pnpm run verify:android",
    "verify": "pnpm run verify:db-contracts && pnpm run verify:apps",
    "release:notes:prepare": "pnpm run verify:db-contracts && pnpm run verify:notes-web",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "init": "node scripts/fetch-infisical.mjs --all",
    "cloud:install": "bash scripts/cloud-agent-install.sh",
    "cloud:start": "bash scripts/cloud-agent-start.sh",
    "create:next-app": "node scripts/create-next-app.js"
  },
  "devDependencies": {
    "@infisical/sdk": "^4.0.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.5",
    "typescript": "5.8.3"
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.11"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ]
  }
}
