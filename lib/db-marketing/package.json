{
  "name": "@lib/db-marketing",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./notes-search-constants": "./notes-search-constants.ts",
    "./contracts/notes-app": "./contracts/notes-app.ts",
    "./db/postgres": "./lib/db/postgres.ts",
    "./generated/*": "./generated/*",
    "./generated/typescript/db-types": "./generated/typescript/db-types.ts",
    "./lib/*": "./lib/*.ts",
    "./services/notes-app": "./services/notes-app.ts",
    "./testing/*": "./testing/*.ts",
    "./sql/note": "./sql/note/index.ts",
    "./sql/user": "./sql/user/index.ts",
    "./sql/*": "./sql/*.ts"
  },
  "scripts": {
    "notes:contract:check": "node scripts/generate-app-contract.mjs --check",
    "notes:contract:generate": "node scripts/generate-app-contract.mjs --write",
    "app:contracts:check": "pnpm notes:contract:check",
    "app:contracts:generate": "pnpm notes:contract:generate",
    "check-types": "tsc --noEmit && pnpm notes:contract:check",
    "db:schema:snapshot": "bash scripts/snapshot-schema.sh",
    "db:types:generate": "node scripts/generate-types.mjs",
    "db:migrate": "node scripts/migrate.mjs",
    "db:verify": "node scripts/verify-contract.mjs",
    "db:migrate:baseline": "node scripts/baseline.mjs",
    "db:migration:new": "node scripts/new-migration.mjs",
    "db:sync": "pnpm db:migrate && pnpm db:schema:snapshot && pnpm db:types:generate && pnpm notes:contract:generate",
    "db:embeddings:regenerate": "node scripts/regenerate-embeddings.mjs"
  },
  "dependencies": {
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@lib/config": "workspace:*",
    "@types/pg": "^8.11.10",
    "typescript": "5.9.2"
  }
}
